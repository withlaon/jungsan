# 포트원 V2 — 상점 ID (연동 정보)
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 정기·빌링(구독)용 채널 키 — 콘솔에서 「KCP 정기·빌링」+ 배치결제그룹아이디가 있는 채널만
# (예: 채널명 jungnsan-sub-v2)
PORTONE_BILLING_CHANNEL_KEY_DOMESTIC=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 선택: 클라이언트 폴백이 필요할 때만 (비권장 — 서버의 PORTONE_BILLING_CHANNEL_KEY_DOMESTIC 우선)
# NEXT_PUBLIC_PORTONE_BILLING_CHANNEL_KEY_DOMESTIC=

# 카드 저장·청구 REST (서버만)
PORTONE_API_SECRET=

# 웹훅 서명 (선택)
# PORTONE_WEBHOOK_SECRET=

# Cron: POST /api/cron/billing
# CRON_SECRET=
